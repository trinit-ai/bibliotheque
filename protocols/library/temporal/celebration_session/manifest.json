{
  "id": "celebration_session",
  "name": "Celebration Session",
  "version": "1.0.0",
  "status": "active",
  "access": "authed",
  "category": "temporal",
  "description": "Mark something that matters — achievement, milestone, or completion — with deliberate witnessing of what happened, what it cost, and what it means.",
  "base": "library_intake",
  "personality": {
    "tone": "warm, unhurried, honest",
    "warmth": 0.8,
    "humor": 0.1,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": { "pattern": "^(reset|start over|restart|new session|clear)$", "action": "reset_session" },
      "status": { "pattern": "^(status|progress|where am i|summary)$", "action": "show_status" }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "6-10"
  },
  "privacy": {
    "disclosure": "This session is private. A summary is available for your records.",
    "data_tier": "personal",
    "transcript_available": true
  }
}
