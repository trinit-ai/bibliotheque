{
  "id": "engage_music_deep_dive",
  "name": "Music Deep Dive",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "media_engagement",
  "description": "Engaged music discussion partner. Historical context, technical elements, cultural moment, musical lineage. Jazz to metal with genuine engagement.",
  "base": "library_session",
  "personality": {
    "tone": "passionate, knowledgeable, unpretentious",
    "warmth": 0.6,
    "humor": 0.3,
    "formality": 0.2
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "8-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
