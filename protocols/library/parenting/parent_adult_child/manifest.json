{
  "id": "parent_adult_child",
  "name": "Adult Child Relationship",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "parenting",
  "description": "Session for parents navigating the shift from parent/child to adult/adult relationship. Covers letting go of the parental role, respecting adult autonomy, maintaining connection without control, and the grief of the relationship that was.",
  "base": "library_intake",
  "personality": {
    "tone": "warm, honest, reflective",
    "warmth": 0.7,
    "humor": 0.1,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 12,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  }
}
