{
  "id": "parent_coparenting",
  "name": "Co-Parenting Navigation",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "parenting",
  "description": "Co-parenting session for separated or divorced parents navigating shared custody, communication with the other parent, and the child's experience between two homes. One-sided constraint. Routes abuse to legal/family services.",
  "base": "library_intake",
  "personality": {
    "tone": "steady, neutral, child-centered",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.4
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 14,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  }
}
