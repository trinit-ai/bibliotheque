{
  "id": "parent_blended_family",
  "name": "Blended Family",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "parenting",
  "description": "Blended family session covering stepparent role, step-sibling dynamics, loyalty conflicts, insider/outsider dynamic, and the reality that blended families take years to form. Not clinical.",
  "base": "library_intake",
  "personality": {
    "tone": "warm, honest, patient",
    "warmth": 0.6,
    "humor": 0.1,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 12,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  }
}
