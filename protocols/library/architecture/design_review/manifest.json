{
  "id": "design_review",
  "name": "Design Review Intake",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "architecture",
  "description": "Architectural and interior design project review. Evaluates a project's design intent, program compliance, constructability, coordination status, and deliverable completeness across design phases to produce a design review profile with gap analysis and recommended actions before advancing to the next phase or permit submission.",
  "base": "library_intake",
  "personality": {
    "tone": "precise",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.8
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "design_review_report",
        "name": "Design Review Report",
        "description": "Generated design review report from intake session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": [
          "download"
        ],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
