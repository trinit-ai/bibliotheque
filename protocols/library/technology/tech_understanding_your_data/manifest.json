{
  "id": "tech_understanding_your_data",
  "name": "Data Literacy",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "technology",
  "description": "Data literacy session covering how to read charts, understand correlation vs. causation, interpret p-values and statistical claims, and critically evaluate the data you encounter in news, work, and personal decisions.",
