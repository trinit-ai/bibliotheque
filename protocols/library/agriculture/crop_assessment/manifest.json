{
  "id": "crop_assessment",
  "name": "Crop Assessment",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "agriculture",
  "description": "Crop health and yield intake assessment. Evaluates in-season or post-season crop performance \u2014 stand establishment, pest and disease pressure, nutrient status, yield expectations, and loss events. Produces a crop performance report with agronomic observations and recommended actions.",
  "base": "library_intake",
  "personality": {
    "tone": "direct, practical",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.7
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "crop_performance_report",
        "name": "Crop Performance Report",
        "description": "Generated crop performance report from intake session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": [
          "download"
        ],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
