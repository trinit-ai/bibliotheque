{
  "id": "farm_intake",
  "name": "Farm Intake",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "agriculture",
  "description": "General farm operations intake. The foundational agriculture pack \u2014 establishes the operation's identity, land base, enterprise mix, financial structure, and operational profile. Produces a farm profile record that downstream agriculture packs inherit as their starting context.",
  "base": "library_intake",
  "personality": {
    "tone": "professional, direct",
    "warmth": 0.7,
    "humor": 0.0,
    "formality": 0.7
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "farm_profile",
        "name": "Farm Profile",
        "description": "Generated farm profile from intake session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": [
          "download"
        ],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
