{
  "id": "grief_arc",
  "name": "Grief Arc",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "chains",
  "description": "Multi-session arc for grief processing — death, loss, estrangement, ambiguous grief. Cannot be rushed. Entry assesses where the person is and may start at any point in the sequence. Highly variable session count and pacing.",
  "base": "library_arc",
  "personality": {
    "tone": "gentle, steady, present",
    "warmth": 0.9,
    "humor": 0.0,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "arc",
    "sessions_in_arc": 4,
    "estimated_total_turns": "30-80"
  },
  "privacy": {
    "disclosure": "Session content carries forward across arc sessions via vault inheritance.",
    "data_tier": "personal_arc",
    "transcript_available": true
  }
}
