        "id": "checkin_info",
        "label": "Check-In",
        "icon": "Heart",
        "type": "pack",
        "title": "Check-In Information",
        "description": "Captured securely. Encrypted at rest. Never sent to AI.",
        "submit_label": "Save to Vault",
        "success_message": "Check-in info saved.",
        "endpoint": "/api/datarail/submit",
        "fields": [
          { "id": "participant_name", "type": "text", "label": "Name", "placeholder": "Full name", "required": true, "pii": true },
          { "id": "participant_email", "type": "email", "label": "Email", "placeholder": "you@example.com", "required": true, "pii": true },
          { "id": "practice_type", "type": "select", "label": "Practice Type", "required": false, "options": ["Meditation", "Journaling", "Breathwork", "Movement", "Reflection", "Other"] },
          { "id": "frequency", "type": "select", "label": "Frequency", "required": false, "options": ["Daily", "Weekly", "As Needed"] },
          { "id": "intention", "type": "text", "label": "Intention", "placeholder": "What are you working toward?", "required": false, "pii": false }
        ]
      }
    ]
  },

