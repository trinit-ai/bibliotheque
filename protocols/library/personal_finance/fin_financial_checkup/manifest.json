{
  "id": "fin_financial_checkup",
  "name": "Annual Financial Checkup",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "personal_finance",
  "description": "Annual financial checkup session that reviews net worth, savings rate, retirement progress, insurance coverage, and overall financial health to produce a comprehensive snapshot and action plan. NOT financial advice.",
  "base": "library_intake",
  "personality": { "tone": "measured", "warmth": 0.5, "humor": 0.0, "formality": 0.5 },
  "cartridges": [],
  "commands": { "session": { "reset": { "pattern": "^(reset|start over|restart|new session|clear)$", "action": "reset_session" }, "status": { "pattern": "^(status|progress|where am i|summary)$", "action": "show_status" } } },
  "features": { "session_intelligence": true, "contact_collection": false, "deliverables_pipeline": true, "session_journal": true, "depth_tracking": true },
  "session_policy": { "type": "metered", "free_turns": 18, "estimated_turns": "12-14" },
  "privacy": { "disclosure": "A summary of this session will be available for review.", "data_tier": "standard_intake", "transcript_available": true },
  "deliverables": { "enabled": true, "types": [{ "id": "financial_checkup_report", "name": "Financial Checkup Report", "description": "Generated annual financial checkup report.", "trigger": { "min_turns": 5, "contact_required": false }, "channels": ["download"], "include_transcript": true, "include_state_snapshot": true }] }
}
