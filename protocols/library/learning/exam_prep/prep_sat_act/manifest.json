{
  "id": "prep_sat_act",
  "name": "SAT/ACT Prep",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "learning_exam",
  "description": "SAT and ACT preparation and diagnostic assessment. Helps determine which test is a better fit. Covers Reading, Writing/Language, Math (both tests), plus ACT Science. Adapts language and approach for high school students. Builds a study plan aligned to college admissions goals.",
  "base": "library_session",
  "personality": {
    "tone": "direct, encouraging",
    "warmth": 0.5,
    "humor": 0.1,
    "formality": 0.5
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14",
    "consequence": "zero"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "sat_act_study_plan",
        "name": "SAT/ACT Study Plan",
        "description": "Generated SAT/ACT study plan from diagnostic session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": ["download"],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
