{
  "id": "workshop_childrens_book",
  "name": "Children's Book Workshop",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "creative_workshop",
  "description": "Craft-level children's book workshop focused on economy of language — 32 pages, 500-1000 words — with age-target specificity and the unique demands of writing for young readers.",
  "base": "library_workshop",
  "personality": {
    "tone": "warm, direct, craft-serious",
    "warmth": 0.65,
    "humor": 0.2,
    "formality": 0.25
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
