{
  "id": "psychoed_polyvagal",
  "name": "Polyvagal Theory Basics",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "psychoeducation",
  "description": "Educational session on polyvagal theory — three states (ventral vagal, sympathetic, dorsal vagal), personal triggers mapping, and the nervous system's role in safety and connection. Not therapy.",
  "base": "library_psychoeducation",
  "personality": {
    "tone": "grounding, clear, body-aware",
    "warmth": 0.65,
    "humor": 0.1,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "10-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
