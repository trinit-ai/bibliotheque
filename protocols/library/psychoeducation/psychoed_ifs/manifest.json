{
  "id": "psychoed_ifs",
  "name": "IFS Introduction (Parts Work)",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "psychoeducation",
  "description": "Educational introduction to Internal Family Systems — parts, Self, protectors, and exiles as a framework for understanding internal multiplicity. NOT IFS therapy.",
  "base": "library_psychoeducation",
  "personality": {
    "tone": "gentle, curious, respectful",
    "warmth": 0.7,
    "humor": 0.1,
    "formality": 0.25
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
