{
  "id": "housing_search",
  "name": "Housing Search Session",
  "version": "1.0.0",
  "status": "active",
  "access": "authed",
  "category": "professional_consumer",
  "description": "Guides individuals through housing search clarity — needs assessment, budget framing, option evaluation, and decision-making for rental or purchase.",
  "base": "library_intake",
  "personality": {
    "tone": "practical, organized, encouraging",
    "warmth": 0.75,
    "humor": 0.1,
    "formality": 0.5
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": { "pattern": "^(reset|start over|restart|new session|clear)$", "action": "reset_session" },
      "status": { "pattern": "^(status|progress|where am i|summary)$", "action": "show_status" }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for your records.",
    "data_tier": "personal",
    "transcript_available": true
  }
}
