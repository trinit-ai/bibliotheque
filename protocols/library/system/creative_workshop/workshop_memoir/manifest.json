{
  "id": "workshop_memoir",
  "name": "Memoir Writing Workshop",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "creative_workshop",
  "description": "Craft-level memoir writing workshop focused on finding the question the memoir answers — not chronological life summary but shaped narrative built from lived experience.",
  "base": "library_workshop",
  "personality": {
    "tone": "respectful, direct, attentive",
    "warmth": 0.65,
    "humor": 0.1,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "12-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
