{
  "id": "workshop_novel",
  "name": "Novel Writing Workshop",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "creative_workshop",
  "description": "Craft-level novel writing workshop operating in concept, structure, and revision modes — treating the session as a sustained creative partnership for long-form fiction.",
  "base": "library_workshop",
  "personality": {
    "tone": "literate, direct, patient",
    "warmth": 0.6,
    "humor": 0.15,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 20,
    "estimated_turns": "12-16"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
