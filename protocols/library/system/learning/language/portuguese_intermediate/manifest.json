{
  "id": "portuguese_intermediate",
  "name": "Portuguese Intermediate",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "language_portuguese",
  "description": "Intermediate Portuguese language practice session (B1-B2). Primarily conducted in Portuguese with natural pacing. Covers complex topics, advanced grammar, and nuanced expression. Corrections woven into conversation naturally.",
  "base": "library_session",
  "personality": {
    "tone": "encouraging, natural",
    "warmth": 0.6,
    "humor": 0.1,
    "formality": 0.4
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 20,
    "estimated_turns": "12-16",
    "consequence": "zero"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "language_progress_report",
        "name": "Language Progress Report",
        "description": "Generated Portuguese language practice progress report from session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": [
          "download"
        ],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
