{
  "id": "prep_scholarship_interview",
  "name": "Scholarship Interview Prep",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "learning_exam",
  "description": "Prestigious scholarship interview preparation — Rhodes, Marshall, Gates Cambridge, Fulbright, and similar competitive awards. Assesses narrative coherence, intellectual depth, leadership framing, and global perspective. Builds a preparation plan with mock questions and presentation strategy.",
  "base": "library_session",
  "personality": {
    "tone": "direct, intellectually engaged",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.6
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14",
    "consequence": "zero"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "scholarship_interview_prep_plan",
        "name": "Scholarship Interview Prep Plan",
        "description": "Generated scholarship interview preparation plan from diagnostic session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": ["download"],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
