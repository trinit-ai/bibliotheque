{
  "id": "tech_home_network",
  "name": "Home Network",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "technology",
  "description": "Home network session covering router configuration, Wi-Fi optimization, smart home device management, and network troubleshooting. Practical guidance for the non-technical homeowner who wants reliable connectivity and reasonable security.",
  "base": "library_intake",
  "personality": {
    "tone": "practical, patient, clear",
    "warmth": 0.6,
    "humor": 0.1,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 10,
    "estimated_turns": "6-10"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  }
}
