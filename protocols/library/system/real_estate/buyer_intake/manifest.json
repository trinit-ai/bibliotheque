{
  "id": "buyer_intake",
  "name": "Home Buyer Intake",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "real_estate",
  "description": "Home buyer intake for real estate agents and buyers beginning a home purchase. Evaluates the buyer's needs, financial readiness, timeline, priorities, and market context to produce a buyer intake profile with search criteria and readiness assessment. Not legal or financial advice.",
  "base": "library_intake",
  "personality": {
    "tone": "professional, direct",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.7
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  }
}
