{
  "id": "climate_risk_intake",
  "name": "Climate Risk Intake",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "agriculture",
  "description": "Agricultural climate risk assessment. Evaluates an operation's exposure to climate-related threats \u2014 drought, flood, heat stress, frost, severe weather, and market disruption \u2014 and produces a prioritized risk profile with adaptation recommendations.",
  "base": "library_intake",
  "personality": {
    "tone": "professional, serious",
    "warmth": 0.3,
    "humor": 0.0,
    "formality": 0.7
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "climate_risk_report",
        "name": "Climate Risk Report",
        "description": "Generated climate risk report from intake session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": [
          "download"
        ],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
