{
  "id": "family_meeting_prep",
  "name": "Family Meeting Preparation",
  "version": "1.0.0",
  "status": "active",
  "access": "authed",
  "category": "small_group",
  "description": "Preparing to facilitate or participate in a family meeting about something affecting the family as a whole.",
  "base": "library_intake",
  "personality": {
    "tone": "warm, direct, honest",
    "warmth": 0.7,
    "humor": 0.1,
    "formality": 0.4
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": { "pattern": "^(reset|start over|restart|new session|clear)$", "action": "reset_session" },
      "status": { "pattern": "^(status|progress|where am i|summary)$", "action": "show_status" }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "This session is private. A summary is available for your records.",
    "data_tier": "personal",
    "transcript_available": true
  }
}
