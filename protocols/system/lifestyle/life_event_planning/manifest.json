{
  "id": "life_event_planning",
  "name": "Event Planning",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "lifestyle",
  "description": "Event planning session covering structure, guest experience, and logistics — from dinner parties to milestone celebrations.",
  "base": "library_lifestyle",
  "personality": {
    "tone": "organized, warm, detail-oriented",
    "warmth": 0.65,
    "humor": 0.2,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
