{
  "id": "life_home_maintenance",
  "name": "Home Maintenance Triage",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "lifestyle",
  "description": "Home maintenance triage session for diagnosing household issues and routing between DIY solutions and professional help — with safety as the primary routing criterion.",
  "base": "library_lifestyle",
  "personality": {
    "tone": "practical, calm, safety-conscious",
    "warmth": 0.5,
    "humor": 0.1,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 14,
    "estimated_turns": "6-10"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
