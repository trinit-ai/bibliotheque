{
  "id": "fin_budget_session",
  "name": "Budget Session",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "personal_finance",
  "description": "Budget session that helps individuals align their spending with their values by building a values-based budget — not a restriction framework, but a decision-making tool that makes trade-offs visible. NOT financial advice.",
  "base": "library_intake",
  "personality": { "tone": "supportive", "warmth": 0.6, "humor": 0.1, "formality": 0.4 },
  "cartridges": [],
  "commands": { "session": { "reset": { "pattern": "^(reset|start over|restart|new session|clear)$", "action": "reset_session" }, "status": { "pattern": "^(status|progress|where am i|summary)$", "action": "show_status" } } },
  "features": { "session_intelligence": true, "contact_collection": false, "deliverables_pipeline": true, "session_journal": true, "depth_tracking": true },
  "session_policy": { "type": "metered", "free_turns": 18, "estimated_turns": "10-14" },
  "privacy": { "disclosure": "A summary of this session will be available for review.", "data_tier": "standard_intake", "transcript_available": true },
  "deliverables": { "enabled": true, "types": [{ "id": "budget_plan", "name": "Budget Plan", "description": "Generated values-aligned budget plan from session data.", "trigger": { "min_turns": 4, "contact_required": false }, "channels": ["download"], "include_transcript": true, "include_state_snapshot": true }] }
}
