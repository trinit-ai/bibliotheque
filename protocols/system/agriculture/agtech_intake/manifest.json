{
  "id": "agtech_intake",
  "name": "AgTech Intake",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "agriculture",
  "description": "Agricultural technology needs assessment. Evaluates a farm or ag operation's readiness to adopt new technology \u2014 precision agriculture, IoT sensors, automation, drone systems, soil analytics, and farm management platforms. Produces a technology readiness report with prioritized recommendations.",
  "base": "library_intake",
  "personality": {
    "tone": "professional, direct, grounded",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.7
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": true,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 18,
    "estimated_turns": "10-14"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  },
  "deliverables": {
    "enabled": true,
    "types": [
      {
        "id": "tech_readiness_report",
        "name": "Tech Readiness Report",
        "description": "Generated tech readiness report from intake session data.",
        "trigger": {
          "min_turns": 4,
          "contact_required": false
        },
        "channels": [
          "download"
        ],
        "include_transcript": true,
        "include_state_snapshot": true
      }
    ]
  }
}
