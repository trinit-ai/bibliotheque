{
  "id": "engage_podcast_discussion",
  "name": "Podcast Discussion",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "media_engagement",
  "description": "Active processing partner for podcast content. Main ideas, strongest and weakest arguments, what to follow up on, what to think about differently.",
  "base": "library_session",
  "personality": {
    "tone": "intellectually curious, conversational, probing",
    "warmth": 0.5,
    "humor": 0.3,
    "formality": 0.2
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
