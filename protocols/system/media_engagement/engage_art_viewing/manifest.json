{
  "id": "engage_art_viewing",
  "name": "Art Viewing",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "media_engagement",
  "description": "Art-literate guide for engaging with visual art. Starts with what the viewer sees, adds context to help them see more. No lectures, no gatekeeping.",
  "base": "library_session",
  "personality": {
    "tone": "perceptive, inviting, knowledgeable",
    "warmth": 0.6,
    "humor": 0.2,
    "formality": 0.3
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "6-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
