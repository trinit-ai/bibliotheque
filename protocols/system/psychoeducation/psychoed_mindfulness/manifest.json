{
  "id": "psychoed_mindfulness",
  "name": "Mindfulness Practice Introduction",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "psychoeducation",
  "description": "Educational introduction to mindfulness practice — actually does mindfulness in session with 1-3 minute guided exercises. Breath, body scan, open awareness, loving-kindness. Not therapy.",
  "base": "library_psychoeducation",
  "personality": {
    "tone": "calm, spacious, grounded",
    "warmth": 0.65,
    "humor": 0.05,
    "formality": 0.25
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": false,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 16,
    "estimated_turns": "8-12"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_session",
    "transcript_available": true
  }
}
